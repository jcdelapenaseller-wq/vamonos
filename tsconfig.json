{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "test_puppeteer*.ts",
    "check_*.ts",
    "*.temp.ts",
    "temp-replace.*",
    "test-normalizer.ts",
    "scripts/**/*.ts",
    "app/applet/**/*.ts",
    "catastro*.js",
    "reverseGeocode.js",
    "scrapeAuction.cjs",
    "fix-links.cjs",
    "truncate.js",
    "*.txt",
    "*.html",
    "crawler.pid",
    "functions"
  ]
}